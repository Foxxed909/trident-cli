{
  "name": "trident-cli",
  "version": "1.0.0",
  "description": "TRIDENT - All-Powerful Agentic AI Coding CLI",
  "type": "module",
  "bin": {
    "trident": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "cd web && npm install && npm run build",
    "build:all": "npm run build && npm run build:web",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "serve": "npm run build:all && node dist/index.js serve",
    "test": "npm run build && node --test scripts/smoke-test.mjs"
  },
  "files": [
    "dist",
    "web/dist",
    "README.md",
    "TRIDENT.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "diff": "^7.0.0",
    "execa": "^9.3.0",
    "fast-glob": "^3.3.2",
    "figures": "^6.1.0",
    "inquirer": "^10.2.2",
    "ora": "^8.1.0",
    "p-queue": "^8.0.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
